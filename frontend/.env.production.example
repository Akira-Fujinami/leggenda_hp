# frontend Web Service用の本番envテンプレート。
#
# NEXT_PUBLIC_*はビルド時にJSバンドルへ焼き込まれるため、コンテナ起動後の
# 環境変数変更では反映されない。Render Docker Build Argとして渡すこと
# (frontend/Dockerfileのbuilderステージ参照)。
#
# クライアントに公開してよい値のみをここに置く。Secret値は
# NEXT_PUBLIC_* に入れてはいけない(ビルド成果物として誰でも読めるため)。

# backend Web ServiceのRender公開URL (末尾スラッシュなし。あっても
# frontend/src/lib/api-client.ts側で正規化されるが、揃えておくのが望ましい)。
NEXT_PUBLIC_API_URL=https://<backend-service>.onrender.com
