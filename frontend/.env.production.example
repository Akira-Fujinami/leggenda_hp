# frontend Web Service用の本番envテンプレート。
#
# 同一Origin BFFプロキシ構成: ブラウザは常にfrontendと同じOrigin
# (https://<frontend-service>.onrender.com) にしかアクセスせず、
# /backend/* へのリクエストは frontend/src/app/backend/[...path]/route.ts が
# サーバー側でLaravel backendへ転送する。これにより、frontend/backendが
# 別onrender.comサブドメインでもXSRF-TOKEN CookieをFrontend JSから読める
# (別ドメインのCookieはブラウザから直接読めないため)。

# --- クライアントに公開される値 (ビルド時にJSバンドルへ焼き込まれる) ---
# 同一Origin配下のプロキシパス。Secretではないため公開して問題ない。
# ビルド時にJSバンドルへ焼き込まれるため、値を変更したら必ずfrontendを再ビルドすること
# (Render Docker Build Argとして渡す。frontend/Dockerfileのbuilderステージ参照)。
NEXT_PUBLIC_API_URL=/backend

# --- サーバー専用の値 (NEXT_PUBLIC_を付けない。ブラウザ/JSバンドルには一切含まれない) ---
# Route Handlerがサーバーサイドで転送する先の、backend Web ServiceのRender公開URL。
# 転送先はこの固定Originのみに限定される(ユーザー入力URLを転送先には使わない)。
BACKEND_URL=https://<backend-service>.onrender.com

# frontend自身の公開Origin。Route HandlerがLaravelへ転送するリクエストの
# Origin/Refererヘッダーをこの信頼済みの値で明示的に上書きするために使う
# (SanctumのEnsureFrontendRequestsAreStateful::fromFrontend()がstatefulと
# 判定できるようにするため。ブラウザから送られてきたOrigin/Refererは信用しない)。
FRONTEND_ORIGIN=https://<frontend-service>.onrender.com
