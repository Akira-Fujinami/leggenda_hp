# ルートの.envは「docker composeがサービス間の配線に使う値」だけを持つ。
# Laravel固有の設定 (APP_KEY, メール設定など) は backend/.env で管理する。
# 詳細な責務分担は README.md を参照。
#
# 例外: SEO_PROVIDER/AI_PROVIDER/ALLOW_MOCK_PROVIDERSは、compose.yamlの
# x-backend-envアンカーでenvironment:として設定されており、Docker Composeの
# 仕様上environment:はenv_file(backend/.env)より優先されるため、ここでも
# 明示する必要がある(backend/.envだけ変更しても反映されないので注意)。

APP_NAME=WebsiteComparison

# ホストに公開するポート
FRONTEND_PORT=3000
BACKEND_PORT=8000
MAILPIT_PORT=8025

# PostgreSQL (docker compose上のpostgresサービスとbackend/.envの両方に
# compose.yamlのenvironment経由で反映される)
POSTGRES_DB=website_comparison
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me

# frontendがブラウザから呼び出すLaravel APIのURL。
# NEXT_PUBLIC_*はNext.jsのビルド時にJSバンドルへ焼き込まれるため、
# 本番でドメインが変わる場合は空欄にせず実際のURLを明示すること
# (例: https://api.example.com)。未設定時はBACKEND_PORTから自動算出される。
# NEXT_PUBLIC_API_URL=http://localhost:8000

# 通常利用(production含む)のデフォルト。APIキー未設定時はunavailable/
# 設定エラーになり、モックへ自動フォールバックしない。詳細はbackend/.env.exampleを参照。
SEO_PROVIDER=semrush
AI_PROVIDER=openai
ALLOW_MOCK_PROVIDERS=false
# ローカル開発でAPIキー無しにデモデータで試したい場合のみ、以下に変更する:
# SEO_PROVIDER=mock
# AI_PROVIDER=mock
# ALLOW_MOCK_PROVIDERS=true
