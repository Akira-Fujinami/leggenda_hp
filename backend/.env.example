APP_NAME=WebsiteComparison
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ja_JP

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=website_comparison
DB_USERNAME=app
DB_PASSWORD=change-me

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=website_comparison_cache

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost

ANALYZER_URL=http://analyzer:3001
ANALYZER_TOKEN=change-me-analyzer-token
ANALYSIS_STORAGE_PATH=/var/analysis-storage
CRAWLER_USER_AGENT="WebsiteComparisonBot/0.1 (+https://example.com/bot)"

# --------------------------------------------------------------------------
# 外部Provider設定
# --------------------------------------------------------------------------
# 通常利用(production含む)を想定したデフォルト。SEMRUSH_API_KEY/OPENAI_API_KEYを
# 設定しない限り、それぞれSEO/AI関連の指標はunavailable、またはAPIキー未設定の
# 明確な設定エラーになります(モックへ自動的にフォールバックすることはありません)。
SEO_PROVIDER=semrush
SEMRUSH_API_KEY=
SEMRUSH_DATABASE=jp
SEMRUSH_TIMEOUT=30
SEMRUSH_MAX_RETRIES=1
SEMRUSH_DAILY_UNIT_LIMIT=
SEMRUSH_CACHE_TTL_HOURS=24

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_TIMEOUT=60
AI_MAX_RETRIES=1
AI_MAX_INPUT_TOKENS=
AI_MAX_OUTPUT_TOKENS=2000

# ALLOW_MOCK_PROVIDERSは、SEO_PROVIDER=mock / AI_PROVIDER=mockを許可するための
# 明示的なスイッチです(通常起動時に意図せずデモデータが使われるのを防ぐため)。
# production環境ではAPP_ENV判定により、この値に関わらずMock Providerは
# 常に拒否されます。ローカル開発でAPIキーを用意せずデモデータのまま試したい
# 場合のみ、下の3行のコメントを外してtrueにし、SEO_PROVIDER/AI_PROVIDERを
# mockに変更してください。
ALLOW_MOCK_PROVIDERS=false
# ALLOW_MOCK_PROVIDERS=true
# SEO_PROVIDER=mock
# AI_PROVIDER=mock
