# backend Web Service / normal・heavy・external worker 共通の本番envテンプレート。
# 値は例であり、Secretはここに書かない(Renderダッシュボードで直接設定すること)。
#
# ここではCORS/Sanctum/Session Cookie関連を中心に、Render標準URL構成と
# カスタムドメイン構成の2パターンを併記する。切り替えはenvの値のみで行い、
# コード変更は不要 (backend/config/cors.php, sanctum.php, session.php は
# いずれもenv経由でのみ挙動が変わる)。

APP_NAME=WebsiteComparison
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_URL=

# --------------------------------------------------------------------------
# CORS / Sanctum / Session Cookie
# --------------------------------------------------------------------------
# 以下は2パターンのうち、実際に採用する方の値だけを設定すること。
# 両方同時に書いても後勝ちで一方しか有効にならないため、片方はコメントのまま残すか削除する。
#
# --- パターンA: Render標準URL同士 (frontend/backendが別onrender.comサブドメイン) ---
# frontendとbackendの2nd-level domainが異なる(onrender.com自体は共有できる
# 親ドメインとして使えない)ため、SESSION_DOMAINは空のままにし、Cookieを
# 発行元(backend)のホストだけに限定する。SameSite=noneが必須になる
# (別サイト間のCookie送信を許可する必要があるため)ので、SESSION_SECURE_COOKIEも
# 必ずtrueにする(SameSite=noneはSecureとの組み合わせでしかブラウザに受理されない。
# 設定を誤ると config:cache 実行時に例外で検知される)。
#
# 【注意】Render標準URL同士の構成は、ブラウザのサードパーティCookie制限
# (SafariのITP、Chromeの将来的な制限強化など)の影響を受ける可能性がある。
# 恒久運用よりも動作確認目的の暫定構成と位置づけ、本番運用にはカスタムドメイン化
# (パターンB)を推奨する。
#
# FRONTEND_URL=https://<frontend-service>.onrender.com
# SANCTUM_STATEFUL_DOMAINS=<frontend-service>.onrender.com
# SESSION_DOMAIN=
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=none
#
# --- パターンB: カスタムドメイン (frontend/backendが同じ親ドメインのサブドメイン、推奨) ---
# frontend: app.example.com / backend: api.example.com のように親ドメイン(example.com)を
# 共有できる場合、SESSION_DOMAINに先頭ドット付きの親ドメインを設定することで
# サードパーティCookie制限の影響を受けにくいSameSite=laxのまま運用できる。
#
# FRONTEND_URL=https://app.example.com
# SANCTUM_STATEFUL_DOMAINS=app.example.com
# SESSION_DOMAIN=.example.com
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

FRONTEND_URL=
# CORS_ALLOWED_ORIGINSは、FRONTEND_URL以外にも追加でCORSを許可したいOriginが
# ある場合のみカンマ区切りで設定する。単一フロントエンドのみなら空のままでよい。
CORS_ALLOWED_ORIGINS=
SANCTUM_STATEFUL_DOMAINS=
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=none

MAIL_MAILER=
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

ANALYZER_URL=
ANALYZER_TOKEN=
ANALYSIS_STORAGE_PATH=/var/analysis-storage

SEO_PROVIDER=semrush
ALLOW_MOCK_PROVIDERS=false
SEMRUSH_API_KEY=
SEMRUSH_DATABASE=jp

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
