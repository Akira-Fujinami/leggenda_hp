# backend Web Service / normal・heavy・external worker 共通の本番envテンプレート。
# 値は例であり、Secretはここに書かない(Renderダッシュボードで直接設定すること)。
#
# 【本番構成】frontendはNext.jsの同一Origin BFFプロキシ(frontend/src/app/backend/
# [...path]/route.ts)経由でこのbackendへアクセスする。ブラウザは常に
# frontendと同じOriginにしかアクセスせず、frontend Route Handlerがサーバー側で
# backendへ転送するため、Cookie(XSRF-TOKEN・セッション)はfrontendのOriginの
# ファーストパーティCookieとして保存される。これによりSameSite=Noneは不要になり、
# カスタムドメイン/サブドメインも不要(*.onrender.com標準URLのままで良い)。

APP_NAME=WebsiteComparison
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# SESSION_DRIVER=databaseはRender Postgresへ保存する構成(推奨・既定)。
# Redisの provisioning/接続に依存せずセッションが永続化されるため、
# Redis未設定・接続断・maxmemory-policyによるキー追い出し等で
# 「ログインしてもすぐログアウトする」事態を避けられる。
# sessionsテーブルはLaravel標準の 0001_01_01_000000_create_users_table.php
# マイグレーションで既に作成される(usersテーブルと同じマイグレーションに含まれる。
# 追加のmigrationは不要)。
#
# Redisをキャッシュ/キューとして既に使っている場合、SESSION_DRIVER=redisも選択肢だが、
# その場合はREDIS_URL(Render Key ValueのInternal Connection String)が
# 実際に設定されていることを必ず確認すること。未設定のまま
# SESSION_DRIVER=redisにすると、REDIS_HOSTが既定値127.0.0.1へフォールバックし、
# コンテナ内に存在しないRedisへ接続しようとして失敗する
# (=セッションが保存されず、ログイン直後にログアウトしたように見える不具合の典型例)。
SESSION_DRIVER=database
QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_URL=

# --------------------------------------------------------------------------
# CORS / Sanctum / Session Cookie
# --------------------------------------------------------------------------
# FRONTEND_URLはfrontend Web ServiceのRender公開URL(ブラウザが実際にアクセスするURL)。
# ブラウザは同一Origin経由でしかbackendへアクセスしないためCORSは実質使われないが、
# 直接backendを叩くクライアント向けの保険として引き続き設定しておく。
FRONTEND_URL=https://<frontend-service>.onrender.com
# CORS_ALLOWED_ORIGINSは、FRONTEND_URL以外にも追加で許可したいOriginが
# ある場合のみカンマ区切りで設定する。単一フロントエンドのみなら空のままでよい。
CORS_ALLOWED_ORIGINS=

# SanctumのEnsureFrontendRequestsAreStateful::fromFrontend()が、frontend Route Handler
# から転送されるOrigin/Refererヘッダー(値はFRONTEND_ORIGIN、frontend側のenv参照)を
# stateful(Cookieセッション認証対象)と認識するために必要。schemeを含めないこと。
SANCTUM_STATEFUL_DOMAINS=<frontend-service>.onrender.com

# 同一Originプロキシ構成のため、SameSite=Noneは不要。ブラウザはfrontendの
# Originにしかアクセスしないので、通常のfirst-party Cookieと同じSameSite=laxで良い。
# SESSION_DOMAINは環境変数として一切設定しない(空文字すら残さない)こと。
# 明示的に空文字を設定した場合とenv自体が存在しない場合とでLaravelの挙動に
# 差は無いが(env('SESSION_DOMAIN')はどちらもnullを返す)、意図を明確にするため
# このテンプレートにも敢えて書かない。
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
# 単位は分。120分(2時間)操作が無ければ失効する。数分でログアウトする場合、
# ここではなくセッション自体が永続化されていない(SESSION_DRIVER/Redis接続/
# APP_KEYの不安定さ等)を疑うこと。
SESSION_LIFETIME=120
# 他環境・他アプリのセッションCookieと名前が衝突しないよう明示する
# (未設定時は "websitecomparison-session" のようにAPP_NAMEから自動生成される)。
SESSION_COOKIE=leggenda_hp_session

MAIL_MAILER=
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

ANALYZER_URL=
ANALYZER_TOKEN=
ANALYSIS_STORAGE_PATH=/var/analysis-storage

SEO_PROVIDER=semrush
ALLOW_MOCK_PROVIDERS=false
SEMRUSH_API_KEY=
SEMRUSH_DATABASE=jp

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
