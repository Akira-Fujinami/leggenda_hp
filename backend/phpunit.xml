<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <!--
            <env>ではなく<server>を使うこと、かつforce="true"が必須。
            理由: backend/.env はDocker Composeのenv_file/environment経由で
            コンテナのOS環境変数として先に注入されており、PHP起動時に
            $_SERVERへ複製される。Laravelのenv()は内部でvlucas/phpdotenvの
            RepositoryBuilder::createWithDefaultAdapters()を使っており、
            読み取り優先順位は ServerConstAdapter($_SERVER) → EnvConstAdapter($_ENV)
            → PutenvAdapter(putenv/getenv) の順(RepositoryBuilder::DEFAULT_ADAPTERS)。
            PHPUnitの<env>はgetenv()/$_ENVしか更新せず$_SERVERには書き込まないため、
            優先度の高い$_SERVERに残ったDocker由来の値(pgsql/redis等)が勝ってしまい、
            テスト用の値がforce="true"を付けても一切反映されなかった
            (実機検証済み)。<server>は$_SERVERを直接上書きするため、これで解決する。
            この設定を誤ると、RefreshDatabase等が実際の開発用Postgres/Redisに対して
            実行されてしまう重大な問題になるため、変更時は必ず実際に
            config('database.default')等を出力して検証すること。
        -->
        <server name="APP_ENV" value="testing" force="true"/>
        <server name="APP_MAINTENANCE_DRIVER" value="file" force="true"/>
        <server name="BCRYPT_ROUNDS" value="4" force="true"/>
        <server name="BROADCAST_CONNECTION" value="null" force="true"/>
        <server name="CACHE_STORE" value="array" force="true"/>
        <server name="DB_CONNECTION" value="sqlite" force="true"/>
        <server name="DB_DATABASE" value=":memory:" force="true"/>
        <server name="DB_URL" value="" force="true"/>
        <server name="MAIL_MAILER" value="array" force="true"/>
        <server name="QUEUE_CONNECTION" value="sync" force="true"/>
        <server name="SESSION_DRIVER" value="array" force="true"/>
        <server name="PULSE_ENABLED" value="false" force="true"/>
        <server name="TELESCOPE_ENABLED" value="false" force="true"/>
        <server name="NIGHTWATCH_ENABLED" value="false" force="true"/>
    </php>
</phpunit>
