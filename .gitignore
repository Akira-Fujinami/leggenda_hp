# Environment
.env
.env.*
!.env.example
!*/.env.example
!.env.production.example
!*/.env.production.example

# Dependencies
node_modules/
vendor/
!docker/vendor/
!docker/vendor/**

# Build output
.next/
dist/
frontend/.next/

# Laravel (backend/storage配下は各ディレクトリの.gitignoreで個別に管理済み)
backend/storage/*.sqlite
backend/public/storage
backend/.phpunit.result.cache

# TypeScript incremental build cache
*.tsbuildinfo

# 開発者ローカルの追加ルート証明書 (社内プロキシ/セキュリティソフト対策)
docker/certs/*.pem
docker/certs/*.crt
!docker/certs/.gitkeep

# OS/Editor
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
